class Vector2
{
    float x, y;

    this(float inX, float inY)
    {
        x = inX;
        y = inY;
    }

    this(int inX, int inY)
    {
        x = inX;
        y = inY;
    }
}

class Vector3
{
    float x, y, z;

    this(float inX, float inY, float inZ)
    {
        x = inX;
        y = inY;
        z = inZ;
    }

    this(int inX, int inY, int inZ)
    {
        x = inX;
        y = inY;
        z = inZ;
    }
}
